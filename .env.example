# Postgres
DATABASE_URL="postgresql://forge:forge@localhost:5432/forge"

# Redis (BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# GitHub App (create at https://github.com/settings/apps/new)
# Required scopes: contents:read, metadata:read, webhooks
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# LLM provider — used ONLY for README narrative sections (see docs/architecture.md)
ANTHROPIC_API_KEY=

# apps/api
API_PORT=4000
JWT_SECRET=

# apps/web
NEXT_PUBLIC_API_URL="http://localhost:4000"
